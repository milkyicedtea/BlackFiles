{
  "name": "blackfiles",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx --bun vite build",
    "everything": "bun run fmt && bun run lint && bun run typecheck",
    "fmt": "biome format --write && cargo fmt",
    "fmt:old": "eslint --fix && cargo fmt",
    "lint": "biome check --write && cargo clippy",
    "lint:old": "eslint . && cargo check",
    "typecheck": "bunx --bun @typescript/native-preview --noEmit"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/modals": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/router-plugin": "^1.168.18",
    "axios": "^1.18.1",
    "mantine-datatable": "^8.3.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "vite": "^8.1.0"
  }
}
